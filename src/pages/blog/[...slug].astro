---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(entry => ({
    params: { slug: entry.id }, props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <article class="max-w-2xl mx-auto">
    <header class="mb-12">
      <time class="text-sm font-medium text-zinc-400">
        {entry.data.pubDate.toLocaleDateString('en-US', {
          year: 'numeric',
          month: 'long',
          day: 'numeric',
        })}
      </time>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tighter text-zinc-900 mt-4 mb-6">
        {entry.data.title}
      </h1>
    </header>

    <div class="prose prose-zinc prose-lg max-w-none">
      <Content />
    </div>
  </article>
</BaseLayout>