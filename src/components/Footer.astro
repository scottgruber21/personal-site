---
// src/components/Footer.astro
const currentYear = new Date().getFullYear();

const links = [
  { name: 'Home', href: '/' },
  { name: 'Case Studies', href: '/case-studies' },
  { name: 'Blog', href: '/blog' },
  { name: 'About', href: '/about' },
  { name: 'Resume', href: '/resume' },
];
---

<footer class="border-t border-zinc-100 bg-white pt-20 pb-12">
  <div class="max-w-4xl mx-auto px-6 sm:px-8">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-16">
      
      {/* Column 1: Brand & Bio */}
      <div class="col-span-1 md:col-span-1">
        <a href="/" class="text-lg font-semibold tracking-tight text-zinc-900">
          Scott Gruber<span class="text-blue-600">.</span>
        </a>
        <p class="mt-4 text-sm text-zinc-500 leading-relaxed">
          Web Development, Technical Marketing & Analytics. Building high-performance data systems with a journalist's attention to detail.
        </p>
      </div>

      {/* Column 2: Navigation */}
      <div>
        <h3 class="text-sm font-bold text-zinc-900 uppercase tracking-widest mb-6">Explore</h3>
        <ul class="space-y-4">
          {links.map(link => (
            <li>
              <a href={link.href} class="text-sm text-zinc-500 hover:text-blue-600 transition-colors">
                {link.name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Column 3: Connect */}
      <div>
        <h3 class="text-sm font-bold text-zinc-900 uppercase tracking-widest mb-6">Connect</h3>
        <ul class="space-y-4">
          <li>
            <a href="https://linkedin.com/in/scottfgruber/" target="_blank" rel="noopener noreferrer" class="text-sm text-zinc-500 hover:text-blue-600 transition-colors flex items-center">
              LinkedIn &rarr;
            </a>
          </li>
          <li>
            <a href="mailto:scott@scottgruber.net" class="text-sm text-zinc-500 hover:text-blue-600 transition-colors flex items-center">
              Email &rarr;
            </a>
          </li>
          <li>
            <span class="text-sm text-zinc-400">Based in Manville, NJ</span>
          </li>
        </ul>
      </div>

    </div>

    {/* Bottom Bar */}
    <div class="pt-8 border-t border-zinc-50 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-xs text-zinc-400 font-medium">
        &copy; {currentYear} Scott Gruber. All rights reserved.
      </p>
      <p class="text-xs text-zinc-300">
        Custom Built with Astro & Tailwind CSS
      </p>
    </div>
  </div>
</footer>