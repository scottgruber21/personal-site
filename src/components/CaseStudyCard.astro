---
// src/components/CaseStudyCard.astro
interface Props {
  title: string;
  description: string;
  href: string;
  metric: string;
}

const { title, description, href, metric } = Astro.props;
---

<a 
  href={href} 
  class="group block p-8 rounded-3xl bg-zinc-50 hover:bg-zinc-100 transition-all duration-300"
>
  {/* The ROI/Analytics Metric */}
  <div class="text-blue-600 font-semibold text-sm mb-4 tracking-wide">
    {metric}
  </div>
  
  {/* Title */}
  <h3 class="text-xl font-semibold tracking-tight text-zinc-900 mb-2 group-hover:text-blue-600 transition-colors">
    {title}
  </h3>
  
  {/* Description */}
  <p class="text-zinc-500 text-sm leading-relaxed">
    {description}
  </p>
</a>