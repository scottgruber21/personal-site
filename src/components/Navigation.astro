---
const navItems = [
  { name: 'Home', href: '/' },
  { name: 'Case Studies', href: '/case-studies' },
  { name: 'Blog', href: '/blog' },
];
---

<header class="bg-white/70 backdrop-blur-lg sticky top-0 z-50 transition-colors duration-300">
  <nav class="max-w-4xl mx-auto px-6 sm:px-8 h-14 flex items-center justify-between">
    <a href="/" class="text-lg font-semibold tracking-tight text-zinc-900">
      Gruber<span class="text-blue-600">.</span>
    </a>
    
    <ul class="flex gap-x-6">
      {navItems.map(item => (
        <li>
          <a 
            href={item.href} 
            class="text-lg font-medium text-zinc-500 hover:text-zinc-900 transition-colors"
          >
            {item.name}
          </a>
        </li>
      ))}
    </ul>
  </nav>
</header>