---
import BaseHead from '../components/BaseHead.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro'; // <-- Import the new footer
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  sd?: object;
}

const { title, description, sd, image } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} sd={sd} image={image} />
  </head>
  <body class="bg-white text-zinc-900 antialiased min-h-screen flex flex-col selection:bg-blue-100 selection:text-blue-900">
    
    <Navigation />

    <main class="flex-grow max-w-4xl mx-auto w-full px-6 sm:px-8 py-16">
      <slot />
    </main>

    {/* Replace the old footer with the new component */}
    <Footer />

  </body>
</html>