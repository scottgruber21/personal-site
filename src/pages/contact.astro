---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "Contact | Scott Gruber";
const pageDescription = "Get in touch for analytics consulting or digital marketing opportunities.";
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <section class="max-w-4xl mx-auto py-12">
    
    <header class="mb-16">
      <h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-zinc-900 mb-6">
        Let's talk.
      </h1>
      <p class="text-xl md:text-2xl text-zinc-500 font-medium leading-relaxed max-w-2xl">
        Whether you have a broken tracking architecture that needs fixing or a full-time role that needs filling, I'm ready to dive in.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-16">
      
      {/* Contact Information */}
      <div>
        <h2 class="text-lg font-semibold text-zinc-900 mb-6">Contact Details</h2>
        <ul class="space-y-6">
          <li>
            <span class="block text-sm font-bold text-zinc-400 uppercase tracking-widest mb-1">Email</span>
            <a href="mailto:scott@scottgruber.net" class="text-lg font-medium text-blue-600 hover:text-blue-700 transition-colors">
              scott@scottgruber.net
            </a>
          </li>
          <li>
            <span class="block text-sm font-bold text-zinc-400 uppercase tracking-widest mb-1">Location</span>
            <span class="text-lg font-medium text-zinc-900">Manville, NJ</span>
          </li>
          <li>
            <span class="block text-sm font-bold text-zinc-400 uppercase tracking-widest mb-1">Network</span>
            <a href="https://linkedin.com/in/scottfgruber/" target="_blank" rel="noopener noreferrer" class="text-lg font-medium text-blue-600 hover:text-blue-700 transition-colors">
              LinkedIn Profile &rarr;
            </a>
          </li>
        </ul>
      </div>

      {/* The Form */}
      <div>
        {/* Replace the action URL with your Formspree or Web3Forms endpoint */}
        <form action="https://api.web3forms.com/submit" method="POST" class="space-y-6">
          <input type="hidden" name="access_key" value="c2af16c2-488b-4754-ba8c-6b2b03f2b1ab">
          <div>
            <label for="name" class="block text-sm font-medium text-zinc-900 mb-2">Name</label>
            <input 
              type="text" 
              name="name" 
              id="name" 
              required
              class="w-full px-4 py-3 rounded-xl border border-zinc-200 bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all outline-none"
              placeholder="Jane Doe"
            />
          </div>

          <div>
            <label for="email" class="block text-sm font-medium text-zinc-900 mb-2">Email</label>
            <input 
              type="email" 
              name="email" 
              id="email" 
              required
              class="w-full px-4 py-3 rounded-xl border border-zinc-200 bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all outline-none"
              placeholder="jane@company.com"
            />
          </div>

          <div>
            <label for="message" class="block text-sm font-medium text-zinc-900 mb-2">Message</label>
            <textarea 
              name="message" 
              id="message" 
              rows="5" 
              required
              class="w-full px-4 py-3 rounded-xl border border-zinc-200 bg-zinc-50 focus:bg-white focus:ring-2 focus:ring-blue-600 focus:border-transparent transition-all outline-none resize-none"
              placeholder="How can I help you?"
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="w-full bg-blue-600 text-white px-6 py-4 rounded-xl text-sm font-semibold hover:bg-blue-700 transition-colors"
          >
            Send Message
          </button>

        </form>
      </div>

    </div>
  </section>
</BaseLayout>